# IMPORTANT: Set VITE_API_URL as a build-time environment variable in the Vercel dashboard.
# Go to: Vercel project → Settings → Environment Variables
# Key:   VITE_API_URL
# Value: https://<your-actual-railway-service>.railway.app/api
#
# Do NOT hardcode the URL here in source control.
# This file is committed, so leave the variable empty (Vercel env var takes precedence at build time).
VITE_API_URL=
